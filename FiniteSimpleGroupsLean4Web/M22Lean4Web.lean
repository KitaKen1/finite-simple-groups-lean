  | 9 => [Gen.e1, Gen.e2, Gen.e3, Gen.e2, Gen.e3, Gen.e1, Gen.e2, Gen.e3, Gen.e2, Gen.e1, Gen.e3, Gen.e2, Gen.e3, Gen.e1]
  | 10 => [Gen.e1, Gen.e2, Gen.e1]
  | 11 => [Gen.e1, Gen.e3, Gen.e2, Gen.e3, Gen.e2, Gen.e1, Gen.e3, Gen.e2, Gen.e1, Gen.e3, Gen.e1, Gen.e2, Gen.e3, Gen.e1, Gen.e2, Gen.e3, Gen.e2, Gen.e3, Gen.e1]
  | 12 => [Gen.e2, Gen.e1, Gen.e3, Gen.e1, Gen.e3, Gen.e2, Gen.e3, Gen.e1, Gen.e2, Gen.e1, Gen.e3, Gen.e2, Gen.e3, Gen.e1, Gen.e3, Gen.e2, Gen.e3, Gen.e1, Gen.e2, Gen.e1, Gen.e3]

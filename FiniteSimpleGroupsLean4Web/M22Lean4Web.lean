theorem conj1_eq (x : Fin 21) (k : Fin 15) :
    l34e1 * elationAt x k * l34e1⁻¹ = elationAt (l34e1 x) (conjIdx1 x k) := by
  rw [l34e1_inv]
  exact Equiv.ext fun p => conj1_pointwise x k p


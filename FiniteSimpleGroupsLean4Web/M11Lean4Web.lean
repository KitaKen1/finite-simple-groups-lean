theorem rep4ARotation_mem_preservingRotationFinset_of_preservingParam
    (r : Fin 6) (s : Fin 2) (i j : Fin 4) :
    rep4APreservingParam r s i j →
      rep4ARotation r s i j ∈ rep4APreservingRotationFinset := by

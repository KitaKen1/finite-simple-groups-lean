  have hstab : Fintype.card (MulAction.stabilizer (ConjAct M11) g) = 11 := by
    rw [conjActStabilizer_card_eq_centralizer_card, hcentralizer]
  rw [hstab] at h
  have hG : Fintype.card (ConjAct M11) = 7920 := by
